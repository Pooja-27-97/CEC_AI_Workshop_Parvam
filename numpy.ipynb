   "source": [
    "import numpy as np\n",
    "\n",
    "# Create a simple array\n",
    "arr = np.array([1, 2, 3, 4, 5])\n",
    "print(\"Array:\", arr)\n",
    "\n",
    "# Perform fast operations\n",
    "squared = arr ** 2\n",
    "print(\"Squared:\", squared)\n",
    "\n",
    "# Mean calculation\n",
    "mean_val = np.mean(arr)\n",
    "print(\"Mean:\", mean_val)"
   ]
  }
